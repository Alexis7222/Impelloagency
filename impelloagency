<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Impello — Outbound for Founders</title>
<meta name="description" content="Impello builds outbound sales systems for early-stage founders who are done relying on referrals.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --cream:#f6f1eb;
  --paper:#ede7df;
  --ink:#1a1714;
  --ink-light:#5c554b;
  --ink-faint:#8e867a;
  --rust:#bf4a2e;
  --rust-hover:#d4563a;
  --rust-pale:rgba(191,74,46,.07);
  --rule:#d4cdc3;
  --display:'Fraunces',Georgia,serif;
  --body:'Outfit',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--cream);color:var(--ink);font-family:var(--body);font-weight:400;line-height:1.65;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{color:inherit;text-decoration:none}
::selection{background:var(--rust);color:var(--cream)}

/* ─── LAYOUT ─── */
.wrap{max-width:1140px;margin:0 auto;padding:0 28px}
.narrow{max-width:680px}

/* ─── NAV ─── */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:22px 0;transition:background .4s,padding .4s,box-shadow .4s}
.nav.stuck{background:rgba(246,241,235,.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);padding:14px 0;box-shadow:0 1px 0 var(--rule)}
.nav-row{display:flex;align-items:center;justify-content:space-between}
.logo{font-family:var(--display);font-size:1.4rem;font-weight:600;letter-spacing:-.03em}
.nav-links{display:flex;gap:32px;align-items:center}
.nav-links a{font-size:.85rem;color:var(--ink-light);transition:color .25s}
.nav-links a:hover{color:var(--ink)}
.nav-cta-link{color:var(--rust) !important;font-weight:500}
.burger{display:none;background:none;border:none;cursor:pointer;width:28px;height:20px;position:relative}
.burger span{display:block;width:100%;height:2px;background:var(--ink);position:absolute;left:0;transition:.3s}
.burger span:nth-child(1){top:0}
.burger span:nth-child(2){top:9px}
.burger span:nth-child(3){top:18px}
.mob-menu{display:none;position:fixed;inset:0;background:var(--cream);z-index:99;flex-direction:column;align-items:center;justify-content:center;gap:36px}
.mob-menu.on{display:flex}
.mob-menu a{font-family:var(--display);font-size:1.8rem;color:var(--ink-light)}
.mob-menu a:hover{color:var(--rust)}
.mob-x{position:absolute;top:22px;right:28px;background:none;border:none;font-size:1.8rem;color:var(--ink);cursor:pointer}

/* ─── HERO ─── */
.hero{padding:160px 0 100px}
.hero-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:end}
.hero h1{
  font-family:var(--display);font-weight:400;
  font-size:clamp(2.6rem,5.2vw,4.4rem);
  line-height:1.08;letter-spacing:-.04em;
  margin-bottom:24px;
}
.hero h1 em{font-style:italic;font-weight:300}
.hero-lead{font-size:1.1rem;color:var(--ink-light);max-width:460px;margin-bottom:40px;line-height:1.75}
.hero-right{padding-bottom:8px}
.hero-right p{font-size:.95rem;color:var(--ink-faint);line-height:1.7;margin-bottom:20px}
.hero-right p strong{color:var(--ink);font-weight:500}

.cta-main{
  display:inline-flex;align-items:center;gap:10px;
  background:var(--rust);color:var(--cream);
  padding:15px 30px;border-radius:6px;font-size:.95rem;font-weight:500;
  transition:background .25s,transform .25s;border:none;cursor:pointer;
}
.cta-main:hover{background:var(--rust-hover);transform:translateY(-1px)}
.cta-main svg{width:15px;height:15px;transition:transform .25s}
.cta-main:hover svg{transform:translateX(3px)}
.cta-ghost{
  display:inline-flex;align-items:center;gap:8px;
  color:var(--ink);font-size:.95rem;font-weight:500;
  padding:15px 0;transition:color .25s;
}
.cta-ghost:hover{color:var(--rust)}

/* ─── DIVIDER ─── */
.rule{border:none;border-top:1px solid var(--rule);margin:0}

/* ─── PROOF (lead with testimonial) ─── */
.proof{padding:80px 0 100px}
.proof-label{font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:32px;font-weight:500}
.proof-card{
  display:grid;grid-template-columns:1fr 320px;gap:64px;align-items:start;
  background:var(--paper);border-radius:14px;padding:52px 56px;
}
.proof-quote{
  font-family:var(--display);font-size:1.55rem;font-weight:350;
  line-height:1.55;letter-spacing:-.01em;font-style:italic;
  margin-bottom:28px;
}
.proof-who{display:flex;align-items:center;gap:14px}
.proof-avatar{
  width:42px;height:42px;border-radius:50%;background:var(--rust);
  display:flex;align-items:center;justify-content:center;
  color:var(--cream);font-family:var(--display);font-weight:600;font-size:1rem;
}
.proof-name{font-weight:500;font-size:.95rem}
.proof-role{font-size:.82rem;color:var(--ink-faint)}
.proof-sidebar h4{font-size:.8rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:16px;font-weight:500}
.proof-stats{display:flex;flex-direction:column;gap:20px}
.proof-stat-val{font-family:var(--display);font-size:2rem;letter-spacing:-.03em;line-height:1.1;font-weight:400}
.proof-stat-label{font-size:.82rem;color:var(--ink-faint);margin-top:2px}

/* ─── WHAT WE DO ─── */
.what{padding:100px 0}
.what-top{display:grid;grid-template-columns:.45fr .55fr;gap:72px;margin-bottom:64px;align-items:start}
.what h2{font-family:var(--display);font-size:clamp(1.9rem,3.2vw,2.8rem);font-weight:400;line-height:1.15;letter-spacing:-.03em}
.what-blurb{font-size:1.02rem;color:var(--ink-light);line-height:1.8}
.what-blurb p+p{margin-top:16px}
.what-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:24px}
.what-card{background:var(--paper);border-radius:12px;padding:36px 32px}
.what-card h3{font-family:var(--display);font-size:1.2rem;font-weight:500;margin-bottom:10px;letter-spacing:-.01em}
.what-card p{font-size:.92rem;color:var(--ink-light);line-height:1.7}
.what-card.tall{grid-row:span 2;display:flex;flex-direction:column;justify-content:space-between;padding:40px 36px}
.what-card.tall h3{font-size:1.35rem;margin-bottom:16px}
.what-card.tall p{font-size:.95rem}
.what-card-num{font-family:var(--display);font-size:4.5rem;color:var(--rule);line-height:1;margin-bottom:12px;font-weight:300}

/* ─── PRICING ─── */
.pricing{padding:100px 0}
.pricing-top{margin-bottom:56px}
.pricing-top h2{font-family:var(--display);font-size:clamp(1.9rem,3.2vw,2.8rem);font-weight:400;line-height:1.15;letter-spacing:-.03em;margin-bottom:12px}
.pricing-top p{color:var(--ink-light);font-size:1.02rem;max-width:520px}
.pricing-layout{display:grid;grid-template-columns:1fr 1.25fr 1fr;gap:20px;align-items:start}
.p-card{border:1px solid var(--rule);border-radius:14px;padding:36px 30px;transition:border-color .3s}
.p-card:hover{border-color:var(--ink-faint)}
.p-card.pop{border-color:var(--rust);background:var(--rust-pale);position:relative;padding:44px 30px 36px}
.p-tag{
  position:absolute;top:-11px;left:28px;
  background:var(--rust);color:var(--cream);
  padding:4px 14px;border-radius:4px;
  font-size:.7rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;
}
.p-tier{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-faint);font-weight:500;margin-bottom:10px}
.p-name{font-family:var(--display);font-size:1.3rem;font-weight:500;margin-bottom:6px;letter-spacing:-.01em}
.p-desc{font-size:.88rem;color:var(--ink-light);line-height:1.6;margin-bottom:22px}
.p-price{font-family:var(--display);font-size:2.2rem;letter-spacing:-.02em;font-weight:400;margin-bottom:2px}
.p-price span{font-family:var(--body);font-size:.85rem;color:var(--ink-faint);font-weight:400}
.p-note{font-size:.78rem;color:var(--ink-faint);margin-bottom:24px}
.p-line{height:1px;background:var(--rule);margin-bottom:22px}
.p-card.pop .p-line{background:rgba(191,74,46,.2)}
.p-list{list-style:none;margin-bottom:28px;display:flex;flex-direction:column;gap:10px}
.p-list li{font-size:.88rem;color:var(--ink-light);padding-left:18px;position:relative;line-height:1.55}
.p-list li::before{content:'–';position:absolute;left:0;color:var(--ink-faint)}
.p-card.pop .p-list li::before{color:var(--rust)}
.p-btn{
  display:block;text-align:center;padding:13px;border-radius:6px;
  font-size:.88rem;font-weight:500;transition:all .25s;cursor:pointer;width:100%;border:none;
}
.p-btn-fill{background:var(--rust);color:var(--cream)}
.p-btn-fill:hover{background:var(--rust-hover)}
.p-btn-line{background:transparent;color:var(--ink);border:1px solid var(--rule)}
.p-btn-line:hover{border-color:var(--ink)}

/* ─── FAQ ─── */
.faq{padding:100px 0}
.faq-heading{font-family:var(--display);font-size:clamp(1.9rem,3.2vw,2.8rem);font-weight:400;line-height:1.15;letter-spacing:-.03em;margin-bottom:48px}
.faq-list{max-width:740px}
.faq-item{border-top:1px solid var(--rule)}
.faq-item:last-child{border-bottom:1px solid var(--rule)}
.faq-q{
  display:flex;justify-content:space-between;align-items:center;gap:20px;
  width:100%;background:none;border:none;text-align:left;
  font-family:var(--body);font-size:1rem;font-weight:500;color:var(--ink);
  padding:22px 0;cursor:pointer;transition:color .25s;
}
.faq-q:hover{color:var(--rust)}
.faq-plus{
  width:24px;height:24px;flex-shrink:0;position:relative;
  transition:transform .35s cubic-bezier(.23,1,.32,1);
}
.faq-plus::before,.faq-plus::after{
  content:'';position:absolute;background:var(--ink-faint);
  top:50%;left:50%;transform:translate(-50%,-50%);transition:background .25s;
}
.faq-plus::before{width:14px;height:1.5px}
.faq-plus::after{width:1.5px;height:14px}
.faq-item.on .faq-plus{transform:rotate(45deg)}
.faq-item.on .faq-plus::before,.faq-item.on .faq-plus::after{background:var(--rust)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .45s cubic-bezier(.23,1,.32,1)}
.faq-a-inner{padding-bottom:24px;color:var(--ink-light);font-size:.95rem;line-height:1.8;max-width:620px}

/* ─── SECOND TESTIMONIAL (inline, different layout) ─── */
.inline-proof{padding:80px 0;display:flex;gap:40px;align-items:start;flex-wrap:wrap}
.inline-proof-text{flex:1;min-width:300px}
.inline-proof-text blockquote{
  font-family:var(--display);font-size:1.35rem;font-weight:350;
  line-height:1.6;font-style:italic;letter-spacing:-.01em;
  border-left:3px solid var(--rust);padding-left:24px;margin-bottom:20px;
}
.inline-proof-meta{padding-left:27px}
.inline-proof-meta strong{display:block;font-weight:500;font-size:.92rem}
.inline-proof-meta span{font-size:.82rem;color:var(--ink-faint)}
.inline-proof-result{
  background:var(--paper);border-radius:10px;padding:28px 32px;
  min-width:200px;flex:0 0 auto;
}
.inline-proof-result .proof-stat-val{margin-bottom:4px}

/* ─── FINAL CTA ─── */
.end-cta{padding:100px 0 120px}
.end-cta-inner{max-width:560px}
.end-cta h2{
  font-family:var(--display);font-size:clamp(2rem,3.5vw,3rem);
  font-weight:400;line-height:1.12;letter-spacing:-.03em;margin-bottom:16px;
}
.end-cta p{color:var(--ink-light);font-size:1.02rem;margin-bottom:36px;line-height:1.75}

/* ─── FLOATING CTA ─── */
.float-cta{
  position:fixed;bottom:20px;right:20px;z-index:90;
  opacity:0;transform:translateY(14px);pointer-events:none;
  transition:all .35s cubic-bezier(.23,1,.32,1);
}
.float-cta.on{opacity:1;transform:translateY(0);pointer-events:auto}
.float-cta a{
  display:flex;align-items:center;gap:8px;
  background:var(--rust);color:var(--cream);
  padding:13px 22px;border-radius:50px;font-size:.85rem;font-weight:500;
  box-shadow:0 4px 20px rgba(191,74,46,.22),0 1px 4px rgba(0,0,0,.08);
  transition:background .25s,transform .25s;
}
.float-cta a:hover{background:var(--rust-hover);transform:translateY(-1px)}
.float-cta a svg{width:14px;height:14px}

/* ─── FOOTER ─── */
.footer{border-top:1px solid var(--rule);padding:40px 0}
.footer-row{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
.footer-left{font-family:var(--display);font-size:1.15rem;font-weight:600;letter-spacing:-.02em}
.footer-mid{display:flex;gap:24px}
.footer-mid a{font-size:.82rem;color:var(--ink-faint);transition:color .25s}
.footer-mid a:hover{color:var(--ink)}
.footer-right{font-size:.78rem;color:var(--ink-faint)}

/* ─── SCROLL REVEAL (simpler, less uniform) ─── */
.sr{opacity:0;transition:opacity .7s ease,transform .7s ease}
.sr.v{opacity:1;transform:none !important}
.sr-up{transform:translateY(24px)}
.sr-left{transform:translateX(-20px)}
.sr-scale{transform:scale(.97)}

/* ─── RESPONSIVE ─── */
@media(max-width:900px){
  .hero-grid{grid-template-columns:1fr;gap:32px}
  .hero-right{display:none}
  .proof-card{grid-template-columns:1fr;gap:40px;padding:36px 28px}
  .what-top{grid-template-columns:1fr;gap:28px}
  .what-grid{grid-template-columns:1fr}
  .what-card.tall{grid-row:auto}
  .pricing-layout{grid-template-columns:1fr;max-width:440px}
  .p-card.pop{order:-1}
  .inline-proof{flex-direction:column}
}
@media(max-width:640px){
  .nav-links{display:none}
  .burger{display:block}
  .hero{padding:130px 0 70px}
  .proof,.what,.pricing,.faq,.end-cta{padding:70px 0}
  .hero h1{font-size:clamp(2rem,8vw,2.8rem)}
  .float-cta{left:16px;right:16px;bottom:14px}
  .float-cta a{width:100%;justify-content:center}
  .footer-row{flex-direction:column;text-align:center}
  .footer-mid{justify-content:center}
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav" id="nav">
  <div class="wrap nav-row">
    <a href="#" class="logo">Impello</a>
    <div class="nav-links">
      <a href="#what">What We Do</a>
      <a href="#pricing">Pricing</a>
      <a href="#faq">FAQ</a>
