<script>
// Nav scroll
const n=document.getElementById('nav');
window.addEventListener('scroll',()=>n.classList.toggle('stuck',scrollY>50),{passive:true});

// Burger
const b=document.getElementById('burger'),m=document.getElementById('mob'),mx=document.getElementById('mobX');
b.addEventListener('click',()=>m.classList.add('on'));
mx.addEventListener('click',()=>m.classList.remove('on'));
document.querySelectorAll('.mob-link').forEach(a=>a.addEventListener('click',()=>m.classList.remove('on')));

// Scroll reveal
const io=new IntersectionObserver(es=>{
  es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('v');io.unobserve(e.target)}});
},{threshold:.12,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.sr').forEach(el=>io.observe(el));

// FAQ
document.querySelectorAll('.faq-q').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const item=btn.parentElement,a=item.querySelector('.faq-a'),open=item.classList.contains('on');
    document.querySelectorAll('.faq-item.on').forEach(i=>{
      if(i!==item){i.classList.remove('on');i.querySelector('.faq-a').style.maxHeight='0'}
    });
    if(open){item.classList.remove('on');a.style.maxHeight='0'}
    else{item.classList.add('on');a.style.maxHeight=a.scrollHeight+'px'}
  });
});

// Floating CTA
const fl=document.getElementById('floater'),hero=document.querySelector('.hero');
new IntersectionObserver(es=>{
  es.forEach(e=>{if(e.target===hero)fl.classList.toggle('on',!e.isIntersecting)});
},{threshold:.2}).observe(hero);

// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',function(e){
    const h=this.getAttribute('href');if(h==='#')return;
    e.preventDefault();document.querySelector(h)?.scrollIntoView({behavior:'smooth',block:'start'});
  });
});
</script>
