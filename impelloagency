  <a href="#faq" class="mob-link">FAQ</a>
  <a href="#go" class="mob-link" style="color:var(--rust)">Free Sales Audit</a>
</div>

<!-- HERO -->
<section class="hero">
  <div class="wrap">
    <div class="hero-grid">
      <div>
        <h1>We build outbound systems for founders who are <em>done waiting for referrals</em></h1>
        <p class="hero-lead">You're great at what you do. But your pipeline still depends on who happens to mention you this month. We fix that.</p>
        <div style="display:flex;gap:24px;align-items:center;flex-wrap:wrap">
          <a href="#go" class="cta-main">
